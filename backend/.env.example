# Clerk secret key — never commit the real value
CLERK_SECRET_KEY=sk_test_your_key_here

# Same publishable key as frontend
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Anthropic API key for paste extraction, event classification, and Ask MealMap.
# If unset, /api/extract falls back to regex, ingest falls back to keywords,
# and /api/assistant returns assistant_not_configured.
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Algolia search-only key for the UNSW society-scrape index (auto-ingest).
ALGOLIA_SEARCH_KEY=your_algolia_search_key_here

# Shared secret required in the x-ingest-secret header to trigger POST /api/ingest.
INGEST_SECRET=change_me

# JSON persistence for the in-memory ticket store (default ./data/store.json).
# Set to :memory: to disable disk writes (used in tests).
# DATA_FILE=./data/store.json

# Load SEED_TICKETS on a fresh boot when no snapshot exists (default off).
# SEED_ON_BOOT=false

# Optional
# PORT=3001
